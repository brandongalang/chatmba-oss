# Local storage
DATABASE_URL=file:./data/chatmba.db

# Bring your own model provider: openai | anthropic | google | openrouter
CHAT_MODEL_PROVIDER=openai
CHAT_MODEL_PRIMARY=gpt-4.1-mini

# Provider credentials. Set only the provider you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# Optional public app metadata
NEXT_PUBLIC_APP_NAME=ChatMBA OSS
